+  // sketchfab-model-details can verify a model's license before use.
+  const licenseJson = model.license ? JSON.stringify(model.license) : "null";
+
   return `
 [Model] ${model.name}
 ID: ${model.uid}
 Creator: ${username}
 Downloadable: ${downloadable}
+License: ${licenseJson}
 Thumbnail: ${thumbnailUrl}
 ${model.description ? `Description: ${model.description}` : ""}
 `;

# Claroty xDome MCP Server
# Generate an API token in xDome via Admin Settings > User Management.

# Base URL of the Claroty xDome REST API. Default is the Claroty SaaS endpoint.
CLAROTY_API_URL=https://api.medigate.io

# Bearer token used in Authorization headers. Required.
CLAROTY_API_TOKEN=

# Verify TLS certificates on the API URL. Default: true. Set to false only for lab/test.
CLAROTY_VERIFY_SSL=true

# Per-request timeout in seconds. Default: 30.
CLAROTY_TIMEOUT=30

# Sliding-window request budget. xDome enforces 2000/min/endpoint and returns 429+Retry-After.
# Lower this if you want a safety margin or are sharing the token across consumers.
CLAROTY_RATE_LIMIT_PER_MIN=2000

# Lab-mode flag (shared with the rest of NetClaw). When "true", ITSM gate
# accepts well-formed CHG\d+ CR numbers without ServiceNow verification.
# DO NOT set in production.
# NETCLAW_LAB_MODE=false

      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--headless=true"
      ],
      "required_keys": []
    },
    "chrome-devtools-mcp-visible": {
      "name": "chrome-devtools-mcp-visible",
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--headless=false"
      ],
      "required_keys": []

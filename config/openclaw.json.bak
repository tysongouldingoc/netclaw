{
  "gateway": {
    "mode": "local"
  },
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace",
      "model": {
        "primary": "anthropic/claude-opus-4-6",
        "fallbacks": [
          "anthropic/claude-sonnet-4-6"
        ]
      }
    }
  },
  "tokenOptimization": {
    "enabled": true,
    "libraryPath": "src/netclaw_tokens",
    "gcfSerializationDefault": true,
    "footerDisplay": "always",
    "sessionTracking": true,
    "pricingOverrideEnvVar": "NETCLAW_TOKEN_PRICING_OVERRIDE"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "security": {
    "mode": "hobby"
  },
  "mcpServers": {
    "forward-mcp": {
      "name": "forward-mcp",
      "command": "mcp-servers/forward-mcp/forward-mcp",
      "args": [],
      "required_keys": []
    },
    "suzieq-mcp": {
      "name": "suzieq-mcp",
      "command": "python3",
      "args": [
        "-u",
        "mcp-servers/suzieq-mcp/server.py"
      ],
      "required_keys": []
    },
    "batfish-mcp": {
      "name": "batfish-mcp",
      "command": "python3",
      "args": [
        "-u",
        "mcp-servers/batfish-mcp/batfish_mcp_server.py"
      ],
      "required_keys": []
    },
    "gnmi-mcp": {
      "name": "gnmi-mcp",
      "command": "python3",
      "args": [
        "-u",
        "mcp-servers/gnmi-mcp/gnmi_mcp_server.py"
      ],
      "required_keys": []
    },
    "azure-network-mcp": {

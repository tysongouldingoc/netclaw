{
  "gateway": {
    "mode": "local"
  },
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace",
      "model": {
        "primary": "anthropic/claude-opus-4-6",
        "fallbacks": [
          "anthropic/claude-sonnet-4-6"
        ]
      }
    }
  },
  "tokenOptimization": {
    "enabled": true,
    "libraryPath": "src/netclaw_tokens",
    "gcfSerializationDefault": true,
    "footerDisplay": "always",
    "sessionTracking": true,
    "pricingOverrideEnvVar": "NETCLAW_TOKEN_PRICING_OVERRIDE"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "security": {
    "mode": "hobby"
  },
  "mcpServers": {
    "forward-mcp": {
      "name": "forward-mcp",
      "command": "mcp-servers/forward-mcp/forward-mcp",
      "args": [],
      "required_keys": [
        "FORWARD_API_BASE_URL",
        "FORWARD_API_KEY",
        "FORWARD_API_SECRET",
        "FORWARD_INSTANCE_ID",
        "FORWARD_DEFAULT_NETWORK_ID",
        "FORWARD_DEFAULT_QUERY_LIMIT",
        "FORWARD_LOCK_DIR",
        "FORWARD_BLOOM_ENABLED",
        "FORWARD_BLOOM_INDEX_PATH",
        "FORWARD_SEMANTIC_CACHE_ENABLED",
        "FORWARD_SEMANTIC_CACHE_DISK_PATH"
      ]
    },
    "suzieq-mcp": {
      "name": "suzieq-mcp",
      "command": "python3",
      "args": [
        "-u",
        "mcp-servers/suzieq-mcp/server.py"
      ],
      "required_keys": [
        "SUZIEQ_API_URL",
        "SUZIEQ_API_KEY",
        "SUZIEQ_VERIFY_SSL",
        "SUZIEQ_TIMEOUT"
      ]
    },
    "batfish-mcp": {
      "name": "batfish-mcp",
      "command": "python3",
      "args": [
        "-u",
        "mcp-servers/batfish-mcp/batfish_mcp_server.py"
      ],
      "required_keys": []
    },
    "gnmi-mcp": {
      "name": "gnmi-mcp",
      "command": "python3",
      "args": [
        "-u",
        "mcp-servers/gnmi-mcp/gnmi_mcp_server.py"
      ],
      "required_keys": []
    },
    "azure-network-mcp": {
      "name": "azure-network-mcp",
      "command": "python",
      "args": [
        "mcp-servers/azure-network-mcp/azure_network_mcp_server.py"
      ],
      "required_keys": [
        "AZURE_TENANT_ID",
        "AZURE_CLIENT_ID",
        "AZURE_CLIENT_SECRET",
        "AZURE_SUBSCRIPTION_ID"
      ]
    },
    "gitlab-mcp": {
      "name": "gitlab-mcp",
      "command": "npx",
      "args": [
        "-y",
        "@zereight/mcp-gitlab"
      ],
      "required_keys": [
        "GITLAB_PERSONAL_ACCESS_TOKEN",
        "GITLAB_API_URL"
      ]
    },
    "chrome-devtools-mcp": {
      "name": "chrome-devtools-mcp",
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--headless=true"
      ],
      "required_keys": []
    },
    "chrome-devtools-mcp-visible": {
      "name": "chrome-devtools-mcp-visible",
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--headless=false"
      ],
      "required_keys": []
    },
    "jenkins-mcp": {
      "name": "jenkins-mcp",
      "command": "python3",
      "args": [],
      "required_keys": [
        "JENKINS_URL",
        "JENKINS_AUTH_BASE64"
      ]
    },
    "atlassian-mcp": {
      "name": "atlassian-mcp",
      "command": "uvx",
      "args": [
        "mcp-atlassian"
      ],
      "required_keys": [
        "JIRA_URL",
        "JIRA_USERNAME",
        "JIRA_API_TOKEN",
        "CONFLUENCE_URL",
        "CONFLUENCE_USERNAME",
        "CONFLUENCE_API_TOKEN"
